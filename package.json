{
  "name": "socialcaution-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=16384 vite",
    "dev:netlify": "netlify dev",
    "build": "vite build",
    "build:basic": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "setup:analytics": "node scripts/setup-analytics.cjs",
    "setup:sentry": "node scripts/setup-sentry.cjs",
    "evaluate:database": "node scripts/evaluate-database.cjs",
    "audit:risk-profiles": "node scripts/audit-risk-profile-coverage.js",
    "deploy:staging": "npm run build && echo 'Deploy to staging'",
    "deploy:production": "npm run lint && npm run type-check && npm run build && echo 'Ready for production deployment'",
    "deploy:demo": "npm run build && echo 'Demo build ready'",
    "deploy": "npm run build && netlify deploy --dir=dist --prod",
    "analyze": "npm run build -- --analyze",
    "health-check": "node scripts/health-check.cjs",
    "test:production": "node scripts/production-test.js",
    "screenshots:capture": "node scripts/capture-screenshots-programmatic.cjs",
    "screenshots:install": "npm install puppeteer --save-dev",
    "verify:translations": "node scripts/verify-translations.js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "@sentry/react": "^10.27.0",
    "@sentry/tracing": "^7.120.4",
    "@stripe/stripe-js": "^2.4.0",
    "@supabase/supabase-js": "^2.87.1",
    "autoprefixer": "^10.4.22",
    "exifr": "^7.1.3",
    "framer-motion": "^12.23.24",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.539.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.6",
    "rss-parser": "^3.13.0",
    "stripe": "^20.0.0",
    "tailwindcss": "^3.4.4",
    "web-vitals": "^3.5.2",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.2.0",
    "puppeteer": "^24.34.0",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.13"
  }
}
