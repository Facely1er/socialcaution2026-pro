# Environment Configuration for SocialCaution
NODE_ENV=production

# Analytics
VITE_REACT_APP_GA_ID=G-XXXXXXXXXX
VITE_REACT_APP_ANALYTICS_ENABLED=true

# API Configuration (if needed for future features)
VITE_REACT_APP_API_BASE_URL=https://api.socialcaution.com
VITE_REACT_APP_API_VERSION=v1

# Feature Flags
VITE_REACT_APP_ENABLE_ADVANCED_ANALYTICS=false
VITE_REACT_APP_ENABLE_USER_FEEDBACK=true
VITE_REACT_APP_ENABLE_EXPORT_DATA=true

# Security
VITE_REACT_APP_ENCRYPT_LOCAL_STORAGE=true
VITE_REACT_APP_SESSION_TIMEOUT=3600000

# External Services (future integrations)
VITE_REACT_APP_SUPPORT_EMAIL=support@ermits.com
VITE_REACT_APP_FEEDBACK_WEBHOOK=https://hooks.socialcaution.com/feedback

# Error Reporting
VITE_REACT_APP_SENTRY_DSN=https://your-sentry-dsn@sentry.io
VITE_REACT_APP_ERROR_REPORTING_ENABLED=true

# Performance Monitoring

# App Store URLs (for mobile app download buttons/links)
# Optional: Override defaults if needed
# VITE_APP_STORE_IOS=https://apps.apple.com/app/socialcaution/id6757679461
# VITE_APP_STORE_ANDROID=https://play.google.com/store/apps/details?id=com.facely1er.socialcaution.mobile
# Optional: Override download page URL for QR codes (default: https://socialcaution.app/download)
# VITE_APP_DOWNLOAD_URL=https://socialcaution.app/download